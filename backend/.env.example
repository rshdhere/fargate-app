# Server
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Postgres connection string (provide a real one when running)
# Local example:  postgres://postgres:postgres@localhost:5432/todos
# RDS example:    postgres://user:pass@db.xxx.us-east-1.rds.amazonaws.com:5432/todos
DATABASE_URL=postgres://user:password@host:5432/todos

# Set to "true" when connecting to managed Postgres (RDS, Neon, Supabase, etc.)
PGSSL=false

# Auth — replace with a long random string in production
JWT_SECRET=replace-me-with-a-long-random-string

# Email verification link target. For local API-only verification use:
# http://localhost:8080/auth/verify-email
EMAIL_VERIFICATION_URL=http://localhost:8080/auth/verify-email

# AWS SQS
AWS_REGION=us-east-1
AWS_SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/todo-email-verification

# Resend
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=Todo App <onboarding@your-domain.com>
